# ==================================
# Environment Configuration
# ==================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY: Never commit .env to Git!
# This .env.example file shows the STRUCTURE
# without revealing actual secrets.
# ==================================

# Server Configuration
NODE_ENV=development
PORT=3000

# CORS - Allowed Origins (comma-separated)
# In production, set this to your actual frontend domain
# Example: ALLOWED_ORIGINS=https://myapp.com,https://www.myapp.com
ALLOWED_ORIGINS=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Docker Hub (used in CI/CD)
DOCKER_USERNAME=your_dockerhub_username

# AWS (used for deployment)
# NEVER put actual keys here — use GitHub Secrets
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_EC2_HOST=
