# Normalize line endings to LF for all text files
# WHY? Prevents the "LF will be replaced by CRLF" warnings on Windows.
# This ensures consistent line endings across Windows, macOS, and Linux
# — which is critical when the code runs on Linux (Docker/EC2) but
# is developed on Windows.
* text=auto eol=lf

# Force LF for shell scripts (they MUST have LF — CRLF breaks bash!)
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.svg binary
